# Approved network URLs fetched by curl/wget/_curl_safe in *.sh / *.zsh.
#
# The "Network installer allowlist" step in security.yml extracts every https
# URL on a fetch line and fails CI if it is not listed here. Adding a new
# remote-code-execution or download source therefore REQUIRES adding it here in
# the same PR — that line is the review checkpoint. Match must be exact (the URL
# as written in source, including ${vars} and HEAD), so a reformatted installer
# URL also triggers review.
#
# Blank lines and lines starting with # are ignored.

# --- macsmith's own repo / releases ---
https://raw.githubusercontent.com/26zl/macsmith/main/bootstrap.sh
https://api.github.com/repos/26zl/macsmith/releases/latest
https://api.github.com/repos/$GITHUB_REPO/releases/latest

# --- toolchain installers (remote code execution — highest scrutiny) ---
https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh
https://raw.githubusercontent.com/nvm-sh/nvm/${nvm_version}/install.sh
https://sh.rustup.rs
https://nixos.org/nix/install

# --- package/version downloads (data, not piped to a shell) ---
https://api.github.com/repos/nvm-sh/nvm/releases/latest
https://distfiles.macports.org/MacPorts/
https://download.swift.org/swiftly/darwin/swiftly.pkg
https://go.dev/dl/?mode=json

# --- network probes (public IP echo) ---
https://ifconfig.me
